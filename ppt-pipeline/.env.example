# Copy this file to .env and fill your own values.
# PowerShell (from workspace root):
# Copy-Item .\ppt-pipeline\.env.example .\ppt-pipeline\.env

# At least one API key is required.
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Sarvam AI (recommended for multilingual narration in Stage 6)
SARVAM_API_KEY=

# Optional model overrides
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
MODEL=anthropic/claude-sonnet-4-5

# Provider routing
# Keep this aligned with whichever keys you actually filled above.
AI_PROVIDER_ORDER=gemini,groq,openrouter

# HTTP behavior
AI_HTTP_TIMEOUT_SECONDS=45
AI_HTTP_MAX_RETRIES=2
AI_HTTP_RETRY_BACKOFF_SECONDS=1.5

# Stage 3 behavior (optional tuning)
STAGE3_PROVIDER_ORDER=gemini,groq,openrouter
STAGE3_AI_TIMEOUT_SECONDS=45
STAGE3_AI_MAX_RETRIES=2
STAGE3_AI_RETRY_BACKOFF_SECONDS=1.5
STAGE3_ENABLE_VISION_ENRICHMENT=1
STAGE3_MAX_VISION_SLIDES=1
STAGE3_VISION_IMAGE_ONLY=1
STAGE3_RATE_LIMIT_SAFE_MODE=1
STAGE3_MAX_REBALANCE_ATTEMPTS=1
STAGE3_REBALANCE_MARGIN_WORDS=80

# TTS defaults
DEFAULT_VOICE=af_heart
DEFAULT_TTS_PROVIDER=auto
DEFAULT_TTS_LANGUAGE=en-IN
SILENCE_DURATION_MS=1500

# TTS provider fallback order for Stage 6
TTS_PROVIDER_ORDER=sarvam,kokoro,piper,gtts

# Stage 6 transcript policy
# Allowed transcript formats: both, json, srt, none
STAGE6_TRANSCRIPT_FORMAT=both
# Current supported mode: always_english
STAGE6_TRANSCRIPT_LANGUAGE_MODE=always_english

# Keyword retention policy for non-English narration
# keep_english: keep configured technical words in English
# translate_all: do not enforce keyword retention
TTS_KEYWORD_POLICY=keep_english
# Comma-separated list of protected terms
TTS_PROTECTED_KEYWORDS=API,SDK,REST,JSON,GitHub,LLM,AI

# Sarvam TTS defaults
SARVAM_TTS_URL=https://api.sarvam.ai/text-to-speech
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_DEFAULT_SPEAKER=shubh
SARVAM_DEFAULT_LANGUAGE=en-IN
SARVAM_TTS_PACE=1.0
SARVAM_TTS_SAMPLE_RATE=24000
SARVAM_MAX_TEXT_CHARS=2400

# Legacy/optional voice controls used in some environments
VOICE=en-US-GuyNeural
VOICE_RATE=+0%
VOICE_PITCH=+0Hz

# Optional local tools
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# Cache behavior: 1 reuse checkpoints, 0 force rebuild
PIPELINE_USE_CACHE=1
